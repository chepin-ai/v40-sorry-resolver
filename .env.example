DEEPSEEK_API_KEY=
DEEPSEEK_API_KEY_2=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DeepSeek V4 migration (2026-07): the legacy aliases deepseek-chat /
# deepseek-reasoner RETIRE on 2026-07-24. Use the real V4 model names below;
# on health-check failure the client automatically probes the legacy alias
# once (two-stage probe) during the transition window.
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONER_MODEL=deepseek-v4-pro
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
LONGCAT_API_KEY=
LONGCAT_BASE_URL=https://api.longcat.chat/openai/v1
LONGCAT_MODEL=LongCat-2.0
V40_VERIFIER=subprocess
V40_NUM_WORKERS=8
